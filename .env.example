# Copy to .env and fill in. Never commit .env (it is gitignored).

# --- Supabase ---------------------------------------------------------------
# From your Supabase project: Settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# From Settings -> Database (used by the Supabase CLI to push migrations)
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=

# Vite needs the public values prefixed with VITE_ to expose them to the web app
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Claude API (AI review) -------------------------------------------------
ANTHROPIC_API_KEY=

# --- Composio (Gmail access for the eval inbox) -----------------------------
COMPOSIO_API_KEY=

# --- Temporal (durable execution of the generated agent) --------------------
TEMPORAL_ADDRESS=
TEMPORAL_NAMESPACE=
TEMPORAL_TASK_QUEUE=receiving-agent
