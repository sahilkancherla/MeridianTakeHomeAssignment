# Copy to .env and fill in. Never commit .env (it is gitignored).

# --- Supabase ---------------------------------------------------------------
# From your Supabase project: Settings -> API
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# From Settings -> Database (used by the Supabase CLI to push migrations)
SUPABASE_DB_PASSWORD=
SUPABASE_PROJECT_REF=

# Vite needs the public values prefixed with VITE_ to expose them to the web app
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Claude API (AI review) -------------------------------------------------
ANTHROPIC_API_KEY=
# How the /api/review endpoint runs:
#   mock   - offline, no key, synthesized from deterministic findings (default; zero-config)
#   live   - always call Claude
#   record - call Claude, then cache the response as a fixture
#   replay - serve a committed fixture (falls back to live if none) — use for the demo/Loom
AI_REVIEW_MODE=mock
# Model for the AI review call. Read from env, so it can be changed without code edits.
AI_REVIEW_MODEL=claude-sonnet-4-5
# How the /api/chat endpoint (AI canvas editing — natural-language edit/ask) runs.
# Same four modes as review; defaults to mock so a fresh clone runs the whole loop.
AI_EDIT_MODE=mock
# Model for the AI canvas-edit call. Falls back to AI_REVIEW_MODEL if unset.
AI_EDIT_MODEL=claude-sonnet-4-5
# Port the FastAPI server (services/api) listens on (Vite proxies /api here).
PORT=8787

# --- Composio (Gmail + any other tools the agent uses) ----------------------
# The agent's tool layer (@meridian/agent) is general: it can call ANY Composio
# tool the spec's System cards imply, not just Gmail.
COMPOSIO_API_KEY=
# Composio connected-account user id the agent acts as (e.g. the receiving inbox owner).
COMPOSIO_USER_ID=default

# --- Agent runtime (@meridian/agent) ----------------------------------------
# Model the generated agent uses for extraction/judgment steps (falls back to
# AI_REVIEW_MODEL, then claude-sonnet-4-5).
AGENT_LLM_MODEL=claude-sonnet-4-5
# Outbound side-effect posture: 'simulate' logs writes (email sends, WMS updates)
# instead of performing them; 'live' actually performs them. Reads are always real.
AGENT_OUTBOUND_MODE=simulate
# A System primitive's credentials (its declared `secrets`) are resolved at runtime via
# ctx.tools.secrets.get(key). In production the worker loads them from the owner-scoped
# `system_secret` table; offline they fall back to env vars named AGENT_SECRET_<KEY>
# (KEY uppercased, non-alphanumerics -> _). Example for a secret keyed "gmail_app_password":
# AGENT_SECRET_GMAIL_APP_PASSWORD=

# --- Temporal (durable execution of the generated agent) --------------------
# Local dev: run `temporal server start-dev` and leave TEMPORAL_ADDRESS=localhost:7233.
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=receiving-agent
